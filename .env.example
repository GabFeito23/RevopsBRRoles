# Required - Airtable
AIRTABLE_API_KEY=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Optional - Gupy (improves Gupy results, but works without it)
GUPY_API_TOKEN=

# Optional - LinkedIn via Google Custom Search (enables LinkedIn source)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
