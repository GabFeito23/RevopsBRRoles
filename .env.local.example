# Required — Neon Postgres (auto-set when you link a Neon database in Vercel)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Required — protects the cron endpoint from unauthorized access
CRON_SECRET=any-random-string-here

# Optional — Gupy API token (improves Gupy results)
GUPY_API_TOKEN=

# Optional — LinkedIn via Google Custom Search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
